generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  privyId       String    @unique @map("privy_id")
  email         String?   @unique
  walletAddress String?   @map("wallet_address")
  displayName   String?   @map("display_name")
  avatarUrl     String?   @map("avatar_url")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  spirits       Spirit[]
  messages      Message[]
  blessings     Blessing[]

  @@map("users")
}

model Spirit {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  tokenId       Int?      @unique @map("token_id")
  name          String
  spiritType    String    @map("spirit_type") // pet_cat, pet_dog, pet_other, human
  personality   Json      // 性格标签 + 自由描述
  photoUrls     String[]  @map("photo_urls")
  metadataUri   String?   @map("metadata_uri")
  homeStyle     String    @default("cozy_room") @map("home_style")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user          User      @relation(fields: [userId], references: [id])
  messages      Message[]
  blessings     Blessing[]
  statuses      SpiritStatus[]

  @@map("spirits")
}

model Message {
  id            String    @id @default(cuid())
  spiritId      String    @map("spirit_id")
  userId        String    @map("user_id")
  role          String    // "user" or "spirit"
  content       String
  createdAt     DateTime  @default(now()) @map("created_at")

  spirit        Spirit    @relation(fields: [spiritId], references: [id])
  user          User      @relation(fields: [userId], references: [id])

  @@index([spiritId, createdAt])
  @@map("messages")
}

model Blessing {
  id            String    @id @default(cuid())
  spiritId      String    @map("spirit_id")
  userId        String    @map("user_id")
  blessingType  String    @map("blessing_type") // candle, flower, prayer, charm
  amount        Float     @default(0)
  txHash        String?   @map("tx_hash")
  createdAt     DateTime  @default(now()) @map("created_at")

  spirit        Spirit    @relation(fields: [spiritId], references: [id])
  user          User      @relation(fields: [userId], references: [id])

  @@index([spiritId, createdAt])
  @@map("blessings")
}

model SpiritStatus {
  id            String    @id @default(cuid())
  spiritId      String    @map("spirit_id")
  content       String    // "正在沙发上打盹"、"去隔壁找花花玩了"
  mood          String    @default("content") // content, playful, sleepy, curious
  createdAt     DateTime  @default(now()) @map("created_at")

  spirit        Spirit    @relation(fields: [spiritId], references: [id])

  @@index([spiritId, createdAt])
  @@map("spirit_statuses")
}

model BlessingItem {
  id            String    @id @default(cuid())
  name          String    @unique
  displayName   String    @map("display_name")
  description   String?
  priceWei      String    @map("price_wei")
  priceCny      Float     @map("price_cny")
  icon          String
  isActive      Boolean   @default(true) @map("is_active")

  @@map("blessing_items")
}
